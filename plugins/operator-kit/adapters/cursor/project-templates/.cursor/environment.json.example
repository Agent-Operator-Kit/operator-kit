{
  "install": "if [ -f package.json ]; then corepack enable >/dev/null 2>&1 || true; if [ -f pnpm-lock.yaml ]; then pnpm install --frozen-lockfile; elif [ -f yarn.lock ]; then yarn install --frozen-lockfile; elif [ -f package-lock.json ]; then npm ci; else npm install; fi; fi",
  "terminals": [
    {
      "name": "Operator status",
      "command": "bash scripts/operator-status.sh || true"
    }
  ]
}
